# Copy this file to `.env` (which is gitignored) and fill in your real values.
#   cp .env.example .env
# Then open .env and paste your key.
#
# Free Linear personal API key:
#   linear.app → Settings → Security & access → Personal API keys → New key
LINEAR_API_KEY=lin_api_REPLACE_ME

# Optional — if unset, the pipeline uses your first Linear team.
# LINEAR_TEAM_ID=

# Run the real agents via your local `claude`. Comment this out (or remove it) to run
# the offline simulated demo instead. With this set, you can drop the command-line prefix:
#   node --env-file=.env example/run.mjs "your feature request"
AGENTS=live

# Which Claude model the agents use (passed as `claude --model ...`). Leave unset to use
# your Claude Code default. Sonnet is faster/cheaper; Opus is more thorough but slower.
CLAUDE_MODEL=claude-sonnet-4-6
