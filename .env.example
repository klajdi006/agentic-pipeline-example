# Copy this file to `.env` (which is gitignored) and fill in your real values.
#   cp .env.example .env
# Then open .env and paste your key.
#
# Free Linear personal API key:
#   linear.app → Settings → Security & access → Personal API keys → New key
LINEAR_API_KEY=lin_api_REPLACE_ME

# Optional — if unset, the pipeline uses your first Linear team.
# LINEAR_TEAM_ID=

# Optional — put this here instead of on the command line to default to live mode.
# AGENTS=live
