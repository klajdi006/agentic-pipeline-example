{
  "name": "taskapp-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Angular standalone frontend — source skeleton (wire into an `ng` workspace to run). Pure logic is unit-tested with ts-jest.",
  "scripts": {
    "test": "jest"
  },
  "dependencies": {
    "@angular/common": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "moduleFileExtensions": ["ts", "js", "json"],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": { "module": "commonjs", "esModuleInterop": true, "experimentalDecorators": true, "useDefineForClassFields": false } }]
    }
  }
}
