{
  "name": "taskapp-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Angular v21 standalone frontend. App runs via the Angular CLI; pure logic is unit-tested with ts-jest.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest"
  },
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "~5.9.0"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "moduleFileExtensions": ["ts", "js", "json"],
    "testRegex": ".*\\.spec\\.ts$",
    "moduleNameMapper": {
      "^@taskapp/shared-types$": "<rootDir>/../../../../libs/shared-types/src"
    },
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": { "module": "commonjs", "esModuleInterop": true, "experimentalDecorators": true, "useDefineForClassFields": false } }]
    }
  }
}
