{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spec.schema.json",
  "title": "FeatureSpec",
  "description": "Structured spec the Spec Writer emits; becomes a Linear ticket. Gated by a human.",
  "type": "object",
  "required": ["ticketKey", "title", "problem", "scope", "changes", "acceptanceCriteria"],
  "additionalProperties": false,
  "properties": {
    "ticketKey": { "type": "string", "pattern": "^TASK-[0-9]+$" },
    "title": { "type": "string", "minLength": 8 },
    "problem": { "type": "string", "minLength": 20 },
    "scope": {
      "type": "object",
      "required": ["in", "out"],
      "properties": {
        "in": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "out": { "type": "array", "items": { "type": "string" } }
      }
    },
    "changes": {
      "type": "object",
      "required": ["frontend", "backend"],
      "properties": {
        "frontend": { "type": "array", "items": { "type": "string" } },
        "backend": { "type": "array", "items": { "type": "string" } },
        "shared": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
          "given": { "type": "string" },
          "when": { "type": "string" },
          "then": { "type": "string" }
        }
      }
    },
    "openQuestions": { "type": "array", "items": { "type": "string" } }
  }
}
